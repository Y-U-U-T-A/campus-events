# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (use MongoDB Atlas URI in production)
MONGODB_URI=mongodb://localhost:27017/campus-events
# Production example:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campus-events

# JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024

# Frontend URL for CORS (set to your Netlify/Render URL in production)
# Not needed if frontend is served from the same Render app
FRONTEND_URL=http://127.0.0.1:5500

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
